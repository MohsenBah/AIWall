# Copy to .env in the repo root or export before `docker compose up`.
#
# Host port AIWall listens on (also passed into the container).
AIWALL_PORT=8080

# Path inside the container; override by bind-mounting a different file to /app/aiwall.yaml.
# AIWALL_CONFIG=/app/aiwall.yaml

# OpenAI provider API key (optional; only needed for gpt-* models).
# OPENAI_API_KEY=sk-...

# AIWall gateway API key (required when gateway_auth.enabled is true).
# AIWALL_API_KEY=your-aiwall-key

# Host port for Ollama when using --profile ollama
# OLLAMA_PORT=11434
