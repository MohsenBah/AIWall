server:
  host: 0.0.0.0
  port: 8080

providers:
  - name: openai
    type: openai-compatible
    base_url: https://api.openai.com/v1
    api_key_env: OPENAI_API_KEY
    models: ["gpt-*"]

  - name: ollama
    type: ollama
    # Local dev: Ollama on the same machine. Docker Compose: use http://ollama:11434
    base_url: http://127.0.0.1:11434
    models: ["llama*", "mistral*", "qwen*"]

policies:
  - name: block-secrets
    when: input.contains_secret
    action: block

  # Alternative: mask secrets and forward instead of blocking
  # - name: redact-secrets
  #   when: input.contains_secret
  #   action: redact

  - name: warn-large-cost
    when: estimated_cost > 1.00
    action: warn

logging:
  store: sqlite:///data/aiwall.db
  log_raw_prompts: false
  retention_days: 90

pricing:
  file: prices.yaml

scanners:
  ignore_examples: true
  entropy:
    enabled: true
    min_length: 20
    threshold: 4.5
  allowlist:
    literals: []
    patterns: []
  rules:
    # Example: disable JWT detection or raise min length for generic keys
    # jwt:
    #   enabled: false
    # generic-api-key:
    #   min_length: 24

# Optional: require clients to present an AIWall-issued API key (off by default).
# gateway_auth:
#   enabled: true
#   api_key_env: AIWALL_API_KEY
